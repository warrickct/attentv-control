# Optional: AWS profile name from ~/.aws/config (e.g. attentv-terraform, iotdevice).
# If unset, the app uses the default credential chain (default profile or env vars).
# AWS_PROFILE=iotdevice

# Optional: AWS region (default: ap-southeast-2)
# AWS_REGION=ap-southeast-2

# Auth: required in production. Used to sign session cookies.
# SESSION_SECRET=your-random-secret-at-least-32-chars

# Optional: DynamoDB table for login users (default: attentv-labelling-users).
# Table must have partition key "username" (string) and attribute "password" (bcrypt hash or plaintext).
# LABELLING_USERS_TABLE=attentv-labelling-users
