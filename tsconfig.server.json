{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "ES2022",
    "target": "ES2020",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "outDir": "./dist-server"
  },
  "include": ["server.ts", "server/**/*.ts", "shared/**/*.ts", "scripts/**/*.ts", "netlify/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
